{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:react/recommended"
  ],
  "overrides": [
    {
      "files": ["**/*.js"],
      "env": {
        "node": true,
        "commonjs": true
      },
      "parserOptions": {
        "sourceType": "script"
      }
    },
    {
      "files": ["vite.config.js"],
      "env": {
        "node": true
      },
      "parserOptions": {
        "sourceType": "module"
      }
    },
    {
      "files": ["**/test/**/*.js"],
      "env": {
        "node": true,
        "commonjs": true,
        "mocha": true
      }
    }
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": [
    "react"
  ],
  "rules": {
    "indent": [
      "error",
      2
    ],
    "linebreak-style": [
      "error",
      "unix"
    ],
    "quotes": [
      "error",
      "single"
    ],
    "semi": [
      "error",
      "always"
    ]
  }
}